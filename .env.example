# ===========================================
# ENVIRONMENT CONFIGURATION
# ===========================================
NODE_ENV=development

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# PostgreSQL Database URL (alternative format)
DATABASE_URL=postgresql://postgres:password@db:5432/bots_api

# Individual Database Parameters
DB_HOST=db                        # Nom du service dans docker-compose ou localhost en local
DB_PORT=5432                      # Port par défaut de PostgreSQL
DB_USERNAME=postgres              # Nom d'utilisateur de la base de données
DB_PASSWORD=password              # Mot de passe de la base de données  
DB_DATABASE=bots_api              # Nom de la base de données

# Legacy Database Variables (pour compatibilité)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=bots_api

# ===========================================
# DISCORD BOT CONFIGURATION
# ===========================================
# Discord Bot Token (obtenu depuis Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Application ID
DISCORD_CLIENT_ID=your_discord_client_id_here

# Discord Guild (Server) Configuration
DISCORD_GUILD_ID=your_guild_id_here
DISCORD_ALLOWED_GUILD_ID=your_guild_id_here
ALLOWED_GUILD_ID=your_guild_id_here

# ===========================================
# DISCORD OAUTH2 CONFIGURATION
# ===========================================
# Discord OAuth2 Client Secret (pour l'authentification web)
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# OAuth2 Redirect URI
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# Discord API Configuration
DISCORD_API_ENDPOINT=https://discord.com/api/v10

# ===========================================
# JWT CONFIGURATION
# ===========================================
JWT_SECRET=dev-jwt-secret-key-change-in-production
JWT_EXPIRATION=24h

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
FRONTEND_URL=http://localhost:3000

# ===========================================
# API CONFIGURATION
# ===========================================
API_PORT=3000
API_HOST=localhost

# ===========================================
# INSTRUCTIONS D'UTILISATION
# ===========================================
# 1. Copiez ce fichier en tant que .env.development ou .env
# 2. Remplacez toutes les valeurs "your_*_here" par vos vraies valeurs
# 3. Obtenez vos tokens Discord depuis : https://discord.com/developers/applications
# 4. Configurez votre base de données PostgreSQL selon vos besoins
# 5. Changez JWT_SECRET par une valeur sécurisée en production
#
# Variables obligatoires à configurer :
# - DISCORD_BOT_TOKEN
# - DISCORD_CLIENT_ID  
# - DISCORD_GUILD_ID
# - DISCORD_CLIENT_SECRET (si OAuth2 utilisé)
# - Database credentials (si différentes des valeurs par défaut)
#
# Pour obtenir vos tokens Discord :
# 1. Allez sur https://discord.com/developers/applications
# 2. Créez une nouvelle application ou sélectionnez-en une existante
# 3. Dans "Bot", copiez le token pour DISCORD_BOT_TOKEN
# 4. Dans "General Information", copiez l'Application ID pour DISCORD_CLIENT_ID
# 5. Dans "OAuth2", copiez le Client Secret pour DISCORD_CLIENT_SECRET